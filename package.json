{
  "name": "pocpet-mint",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "serve:local": "node scripts/serve-dev.mjs --port 5173",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-tauri-release.ps1 && tauri build --no-bundle",
    "package:win:portable": "npm.cmd run tauri:build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-portable-win.ps1 -Target x64",
    "package:web": "npm.cmd run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-web.ps1",
    "tauri:android:init": "tauri android init",
    "tauri:android:build": "tauri android build",
    "package:android:arm64": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-android-arm64-debugsigned.ps1 -AndroidTarget aarch64 -RebuildRust",
    "package:android:arm64:rebuild": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-android-arm64-debugsigned.ps1 -AndroidTarget aarch64 -RebuildRust",
    "package:android:arm64:reuse": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-android-arm64-debugsigned.ps1 -AndroidTarget aarch64",
    "package:desktop": "tauri build --ci --config scripts/tauri-bundle-config.json",
    "package:win:portable:x64": "npm.cmd run package:win:portable",
    "package:win:portable:x86": "npm.cmd run tauri -- build --no-bundle --target i686-pc-windows-msvc && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-portable-win.ps1 -Target x86",
    "package:android:armv7": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-android-arm64-debugsigned.ps1 -AndroidTarget armv7 -RebuildRust",
    "package:android:armv7:rebuild": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-android-arm64-debugsigned.ps1 -AndroidTarget armv7 -RebuildRust",
    "package:android:armv7:reuse": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-android-arm64-debugsigned.ps1 -AndroidTarget armv7"
  },
  "dependencies": {
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5"
  },
  "author": "FrostForge Studio",
  "license": "GPL-3.0-or-later"
}
